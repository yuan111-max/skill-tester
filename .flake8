[flake8]
max-line-length = 100
extend-ignore = E203, W503
exclude =
    .git,
    __pycache__,
    build,
    dist,
    .pytest_cache,
    .eggs
per-file-ignores =
    # __init__.py files may have unused imports
    __init__.py: F401
    # Test files: long lines common in test data
    tests/*: E501
